# ==============================
# Sayit — Environment Variables
# ==============================
#
# Priority:  Environment Variable > config.json > built-in defaults
#
# Set these to use Sayit without editing config.json.
# You can set them in your shell session, add to system environment variables,
# or copy this file to .env (NOT recommended — .env is gitignored but easy to leak).
#
# PowerShell (current session):
#   $env:SAYIT_ALIYUN_API_KEY = "sk-xxxx"
#
# CMD (current session):
#   set SAYIT_ALIYUN_API_KEY=sk-xxxx
#
# Permanent (Windows):
#   System Properties → Environment Variables → New

# ──────────────────────────────────────
#  Aliyun DashScope — ASR + AI Correction
# ──────────────────────────────────────
# Get your key: https://help.aliyun.com/document_detail/2712195.html
# SAYIT_ALIYUN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────
#  VolcEngine / ByteDance Ark — ASR
# ──────────────────────────────────────
# Get your token: https://console.volcengine.com/ark/region:arkCnBeijing/apiKey
# SAYIT_VOLCENGINE_ASR_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SAYIT_VOLCENGINE_ASR_APP_ID=9709109506

# ──────────────────────────────────────
#  VolcEngine / ByteDance Ark — AI Correction
# ──────────────────────────────────────
# SAYIT_VOLCENGINE_AI_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────
#  DeepSeek — AI Correction
# ──────────────────────────────────────
# Get your key: https://platform.deepseek.com/api_keys
# SAYIT_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx